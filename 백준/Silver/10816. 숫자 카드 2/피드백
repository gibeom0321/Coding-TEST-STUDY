import sys
input = sys.stdin.readline

n = int(input())
sangen = sorted(list(map(int, input().split())))
m = int(input())
cards = list(map(int, input().split()))

dic1 = {}
for x in sangen:
    if x in dic1:
        dic1[x] += 1
    else:
        dic1[x] = 1

for element in cards:
    if element in dic1:
        print(dic1[element], end=' ')
    else:
        print(0, end=' ')

이렇게 딕셔너리에 해당하는 값을 넣고 후보값을 돌면서 키에 해당하는 값이 있으면 값을 출력하고 없으면 0 을 출력하는 식으로 해서 깔끔하게 구현함.

